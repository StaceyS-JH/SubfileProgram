     A                                      CHECK(LC)
     A  92                                  DSPATR(PR)
     A                                  6  2'Subject'
     A                                      COLOR(BLU)
     A            DISUBJECT    100A  B  6 12DSPATR(UL)
     A                                      DSPATR(&ATTRSUB)
     A                                      COLOR(GRN)
     A                                      CHECK(LC)
     A  92                                  DSPATR(PR)
     A                                  7  2'Audience'
     A                                      COLOR(BLU)
     A            DIAUDINC     100A  B  7 12DSPATR(UL)
     A                                      DSPATR(&ATTRAUD)
     A                                      COLOR(GRN)
     A                                      CHECK(LC)
     A  92                                  DSPATR(PR)
     A                                  8  2'Expiry (s)'
     A                                      COLOR(BLU)
     A            DIEXPIRY       7S 0B  8 14DSPATR(UL)
